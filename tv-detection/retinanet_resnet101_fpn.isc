experiment_name="retinanet_resne101_fpn"
gpu_type="24GB VRAM GPU"
nnodes = 12
venv_path = "~/.venv/bin/activate"
output_path = "~/outputs/retinanet_resnet101_fpn"
command="train_cycling.py --dataset coco --model retinanet_resnet101_fpn --epochs 30 -b 2 --lr 0.0001  --opt adamw --data-path=/mnt/.node1/Open-Datasets/coco --resume $OUTPUT_PATH/checkpoint.isc --tboard-path $OUTPUT_PATH/tb"

