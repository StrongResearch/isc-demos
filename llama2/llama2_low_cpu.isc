experiment_name = "llama2-test"
gpu_type = "24GB VRAM GPU"
nnodes = 12
venv_path = "~/.llama2env/bin/activate"
output_path = "~/outputs/llama2"
command = "test.py --enable_fsdp --low_cpu_fsdp --use_peft --peft_method lora --train_config.batch_size_training 1 --fsdp_config.pure_bf16 --fsdp_config.fsdp_cpu_offload"